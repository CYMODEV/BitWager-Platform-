    // --- PLAY SESSION LOGIC ---
    let currentRound = 0, hits = 0, misses = 0, score = 0, reactionTimes = [];
    let timerInterval, roundTimeout, lifespanTimeout, roundActive = false, roundStartTime;
    let currentCombo = 0, isFrenzy = false;

    elements.playModeSelect.addEventListener('change', (e) => {
      bitwager.mode = e.target.value;
      if (bitwager.mode === 'fun') {
        elements.wagerAmount.value = 0; elements.wagerAmount.disabled = true; elements.wagerAmount.style.opacity = "0.5";
      } else {
