    function startSession() {
      bitwager.activeWager = parseInt(elements.wagerAmount.value) || 0;
      
      // Compliance Check
      if (bitwager.mode !== 'fun' && bitwager.activeWager > 1000 && bitwager.kycLevel < 2) {
          showFloatingText("KYC Level 2 Required for High Stakes!", window.innerWidth/2, window.innerHeight/2, false);
          elements.epurseModal.classList.add('active');
          return;
      }

      if (bitwager.mode !== 'fun') {
        if (bitwager.activeWager <= 0 || bitwager.activeWager > bitwager.balance) {
            showFloatingText("Insufficient BWT", window.innerWidth/2, window.innerHeight/2, false);
            return;
        }
        updateBalance(-bitwager.activeWager);
        logTransaction(`Wager Entry (${gameDefinition.name})`, -bitwager.activeWager);
      }
      
      resetSession(false);
      elements.aiCoachingContainer.style.display = "none";
      
      // Chat setup
      clearInterval(chatSimInterval);
      chatMessagesBox.innerHTML = '<div style="text-align: center; font-size: 10px; color: var(--text-muted); margin-bottom: 8px;">Match Started</div>';
      
      if (bitwager.mode === 'pvp' || bitwager.mode === 'tournament') {
        document.getElementById("roundsPlayedLabel").textContent = "MATCHMAKING...";
        elements.grid.style.gridTemplateColumns = "1fr";
        elements.grid.innerHTML = '<div style="text-align: center; padding: 40px 0; color: #facc15; font-weight: 800; animation: pulseFrenzy 1s infinite alternate;">Searching Network for Opponents...</div>';
        
        chatWidget.style.display = "flex"; // Show chat
        
        setTimeout(() => {
            sfx.start();
            startRound();
            chatSimInterval = setInterval(simulateIncomingChat, 5000 + Math.random() * 8000);
        }, 2500);
      } else {
        chatWidget.style.display = "none"; // Hide chat for solo
        sfx.start();
        startRound();
      }
    }

    function startRound() {
      if (currentRound >= (gameDefinition.timing?.roundCount || 10)) { finalizeSession(); return; }
      
      currentRound++;
      roundActive = true;
      roundStartTime = performance.now();
      const targetSize = gameDefinition.gridSize || 16;
      const target = Math.floor(Math.random() * targetSize);
      
      updateUI();
      renderGrid(target);
      
      timerInterval = setInterval(() => {
        const remain = Math.max(0, ((gameDefinition.timing?.roundDurationMs || 3000) / 1000) - ((performance.now() - roundStartTime) / 1000));
        document.getElementById("timerLabel").textContent = remain.toFixed(1) + "s";
        if (elements.timerProgress) elements.timerProgress.style.width = `${(remain / ((gameDefinition.timing?.roundDurationMs || 3000) / 1000)) * 100}%`;
      }, 50);

      if (gameDefinition.timing?.targetLifespanMs > 0) {
        lifespanTimeout = setTimeout(() => { if (roundActive) handleAction(null, null, true); }, gameDefinition.timing.targetLifespanMs);
      }
      roundTimeout = setTimeout(() => handleAction(null, null), gameDefinition.timing?.roundDurationMs || 3000);
    }

    function handleAction(index, event, isLifespanTimeout = false) {
      if (!roundActive) return;
      roundActive = false;
      clearInterval(timerInterval); clearTimeout(roundTimeout); clearTimeout(lifespanTimeout);
      
      const isHit = !isLifespanTimeout && index !== null && elements.grid.children[index].classList.contains('cell--target');
      const reaction = (performance.now() - roundStartTime) / 1000;
      let clientX = window.innerWidth / 2, clientY = window.innerHeight / 2;
      
      if (event) { clientX = event.touches?.[0]?.clientX || event.clientX; clientY = event.touches?.[0]?.clientY || event.clientY; }
      
      if (isHit) {
        currentCombo++; hits++;
        let multiplier = Math.min(3, 1 + Math.floor(currentCombo / 3) * 0.5);
        if (currentCombo >= 5) { isFrenzy = true; multiplier = 5; document.querySelector('.grid-wrapper')?.classList.add('frenzy'); }
        
        const pts = Math.floor((gameDefinition.scoring?.baseHitPoints || 10) * multiplier);
        score += pts; reactionTimes.push(reaction);
        if (index !== null) elements.grid.children[index].className = 'cell cell--hit';
        
        sfx.hitCombo(currentCombo); updateComboUI();
        showFloatingText(`+${pts}`, clientX, clientY, true);
      } else {
        currentCombo = 0; isFrenzy = false;
        const gw = document.querySelector('.grid-wrapper');
        if (gw) { gw.classList.remove('frenzy', 'shake'); void gw.offsetWidth; gw.classList.add('shake'); }
        misses++; score -= (gameDefinition.scoring?.baseMissPenalty || 5);
        if (index !== null) elements.grid.children[index].className = 'cell cell--miss';
        
        sfx.miss(); updateComboUI();
        showFloatingText(`-${gameDefinition.scoring?.baseMissPenalty || 5}`, clientX, clientY, false);
      }
      
      updateStats();
      setTimeout(startRound, gameDefinition.timing?.interRoundDelayMs || 300);
    }

    function updateComboUI() {
      const mult = isFrenzy ? 5 : Math.min(3, 1 + Math.floor(currentCombo / 3) * 0.5);
      elements.comboLabel.textContent = isFrenzy ? `FRENZY x${mult}!` : `x${mult}`;
      elements.comboLabel.style.color = isFrenzy ? '#ec4899' : currentCombo > 5 ? '#ef4444' : currentCombo > 2 ? '#facc15' : '#f97316';
    }

    function finalizeSession() {
      const acc = (hits / (hits + misses)) * 100 || 0;
      const tier = determineTier(score, acc);
      elements.tierName.textContent = tier.label || tier.id;
      document.getElementById("roundsPlayedLabel").textContent = "FINISHED";
      elements.aiCoachingContainer.style.display = "block";
      
      clearInterval(chatSimInterval);

      if (tier.id === 'S' || tier.id === 'A') { sfx.win(); fireConfetti(); } else { sfx.lose(); }
      addPlayerXP(Math.max(10, Math.floor(score * (acc / 100))));
      
      let payout = 0;
      if (bitwager.mode !== 'fun' && bitwager.activeWager > 0) {
        payout = Math.floor(bitwager.activeWager * (tier.id === 'S' ? 2.0 : tier.id === 'A' ? 1.5 : tier.id === 'B' ? 1.0 : 0));
        if (payout > 0) { updateBalance(payout); showFloatingText(`+${payout} BWT`, window.innerWidth/2, window.innerHeight/2, true); }
      }
      
      pushToFeed({
        type: 'play', user: 'You', avatar: 'U', game: {id: gameDefinition.name, name: gameDefinition.name, category: gameDefinition.category || "General"},
        tier: tier.id + '-Tier', wager: payout || 0, timestamp: new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}), likes: 0
      });
    }

    function determineTier(s, a) {
      return gameDefinition.tiering?.tiers?.find(t => s >= t.minScore && a >= t.minAccuracyPercent) || { id: "D", label: "D-Tier Practice" };
    }

    function renderGridItems(container, size, design, targetIndex, interactive) {
      container.innerHTML = '';
      container.style = ''; // clear inline styles for fresh layout
      
      const shapeClass = design !== 'rectangle' ? ` cell--${design}` : '';
      const baseClass = interactive ? 'cell' : 'mini-cell';
      const gapSize = interactive ? '12px' : '3px';
      
      if (design === 'square') {
          container.style.display = 'grid';
          container.style.gap = gapSize;
          container.style.gridTemplateColumns = `repeat(${Math.sqrt(size)}, 1fr)`;
          for (let i = 0; i < size; i++) {
              const el = document.createElement('div');
              el.className = `${baseClass}${shapeClass}${i === targetIndex ? ' cell--target target' : ''}`;
              if(interactive) setupCellEvents(el, i);
              container.appendChild(el);
          }
      } else if (design === 'rectangle') {
          container.style.display = 'grid';
          container.style.gap = gapSize;
          let cols = Math.ceil(Math.sqrt(size * 2)); // 2:1 dynamic aspect layout
          container.style.gridTemplateColumns = `repeat(${cols}, 1fr)`;
          for (let i = 0; i < size; i++) {
              const el = document.createElement('div');
              el.className = `${baseClass}${i === targetIndex ? ' cell--target target' : ''}`;
              if(interactive) setupCellEvents(el, i);
              container.appendChild(el);
          }
      } else if (design === 'circle') {
          container.style.position = 'relative';
          container.style.width = '100%';
          container.style.aspectRatio = '1';
          
          let rings = [1];
          let remaining = size - 1;
          let cap = 5;
          while (remaining > 0) {
              rings.push(Math.min(remaining, cap));
              remaining -= cap;
              cap += 6; 
          }
          
          let cellIndex = 0;
          rings.forEach((count, ringIdx) => {
              const radius = ringIdx === 0 ? 0 : (ringIdx * (45 / rings.length));
              for(let i=0; i<count; i++) {
                  if(cellIndex >= size) break;
                  const el = document.createElement('div');
                  el.className = `${baseClass}${shapeClass}${cellIndex === targetIndex ? ' cell--target target' : ''}`;
                  el.style.position = 'absolute';
                  
                  const sz = interactive ? `${80 / rings.length}%` : `${100 / rings.length}%`;
                  el.style.width = sz; el.style.height = sz;
                  if (!interactive) {
                      el.style.maxWidth = '12px'; el.style.maxHeight = '12px';
                  }
                  
                  const angle = (i / count) * Math.PI * 2 - (Math.PI/2);
                  const x = 50 + Math.cos(angle) * radius;
                  const y = 50 + Math.sin(angle) * radius;
                  el.style.left = `calc(${x}% - (${sz} / 2))`;
                  el.style.top = `calc(${y}% - (${sz} / 2))`;
                  
                  if(interactive) setupCellEvents(el, cellIndex);
                  container.appendChild(el);
                  cellIndex++;
              }
          });
      } else if (design === 'triangle') {
          container.style.display = 'flex';
          container.style.flexDirection = 'column';
          container.style.alignItems = 'center';
          container.style.justifyContent = 'center';
          container.style.height = '100%';
          container.style.gap = '0px'; 
          
          let cellIndex = 0;
          let r = 0;
          while(cellIndex < size) {
              const rowDiv = document.createElement('div');
              rowDiv.style.display = 'flex';
              rowDiv.style.gap = '0px'; 
              rowDiv.style.justifyContent = 'center';
              
              const cellsInRow = 1 + (r * 2);
              for(let c=0; c<cellsInRow; c++) {
                  if(cellIndex >= size) break;
                  const el = document.createElement('div');
                  
                  // Invert alternating triangles for perfect geometric tessellation
                  const isInverted = (c % 2 !== 0);
                  const invertedClass = isInverted ? ' cell--triangle-inverted' : '';
                  el.className = `${baseClass}${shapeClass}${invertedClass}${cellIndex === targetIndex ? ' cell--target target' : ''}`;
                  
                  const sz = interactive ? `${68 / Math.sqrt(size)}vw` : '10px';
                  el.style.width = sz; el.style.height = sz;
                  el.style.maxWidth = interactive ? '80px' : '12px';
                  el.style.maxHeight = interactive ? '80px' : '12px';
                  
                  // Interlock inverted bases horizontally by overlapping 50%
                  if (c > 0) {
                      el.style.marginLeft = `calc(${sz} * -0.5)`;
                  }
                  
                  if(interactive) setupCellEvents(el, cellIndex);
                  rowDiv.appendChild(el);
                  cellIndex++;
              }
              container.appendChild(rowDiv);
              r++;
          }
      } else if (design === 'gyro_sphere') {
          container.style.position = 'relative';
          container.style.width = '100%';
          container.style.height = '100%';
          container.style.transformStyle = 'preserve-3d';
          
          // Generate coordinates on a sphere using Fibonacci lattice
          let sphereLayout = [];
          if (interactive && container.dataset.sphereLayout) {
              sphereLayout = JSON.parse(container.dataset.sphereLayout);
          } else {
              const phi = Math.PI * (3 - Math.sqrt(5)); 
              for (let i = 0; i < size; i++) {
                  const y = 1 - (i / (size - 1)) * 2; 
                  const radius = Math.sqrt(1 - y * y); 
                  const theta = phi * i; 
                  
                  const x = Math.cos(theta) * radius;
                  const z = Math.sin(theta) * radius;
                  
                  const lat = Math.asin(y);
                  const lon = Math.atan2(z, x);
                  sphereLayout.push({ lat, lon });
              }
              if (interactive) container.dataset.sphereLayout = JSON.stringify(sphereLayout);
          }

          sphereLayout.forEach((pos, cellIndex) => {
              if (cellIndex >= size) return;
              const el = document.createElement('div');
              const isTarget = cellIndex === targetIndex;
              el.className = `${baseClass} cell--circle ${isTarget ? ' cell--target target' : ''}`;
              el.style.position = 'absolute';
              
              const sz = interactive ? `${80 / Math.sqrt(size)}%` : `25%`;
              el.style.width = sz; el.style.height = sz;
              if (!interactive) {
                  el.style.maxWidth = '10px'; el.style.maxHeight = '10px';
              }
              
              el.style.left = `calc(50% - (${sz} / 2))`;
              el.style.top = `calc(50% - (${sz} / 2))`;
              
              const dist = interactive ? `min(35vw, 130px)` : '20px';
              el.style.transform = `rotateY(${pos.lon}rad) rotateX(${-pos.lat}rad) translateZ(${dist})`;
              el.style.backfaceVisibility = 'hidden'; 
              
              if(interactive) setupCellEvents(el, cellIndex);
              container.appendChild(el);
          });
      } else if (design === 'overlapping_rings') {
          container.style.position = 'relative';
          container.style.width = '100%';
          container.style.aspectRatio = '1';

          let ringLayout;
          if (interactive && container.dataset.ringLayout) {
              ringLayout = JSON.parse(container.dataset.ringLayout);
          } else {
              let numRings = Math.max(2, Math.floor(Math.sqrt(size) / 1.5));
              if (size >= 36) numRings = 4;
              if (size >= 64) numRings = 5;

              let rings = [];
              for (let i = 0; i < numRings; i++) {
                  rings.push({
                      cx: 30 + Math.random() * 40, 
                      cy: 30 + Math.random() * 40, 
                      r: 15 + Math.random() * 25,  
                      startAngle: Math.random() * Math.PI * 2,
                      cells: 0
                  });
              }
              
              for (let i = 0; i < size; i++) rings[i % numRings].cells++;
              
              ringLayout = [];
              rings.forEach(ring => {
                  for (let i = 0; i < ring.cells; i++) {
                      const angle = ring.startAngle + (i / ring.cells) * Math.PI * 2;
                      const jitterMagnitude = Math.min(12, size / 5); 
                      ringLayout.push({
                          x: ring.cx + Math.cos(angle) * ring.r + (Math.random() - 0.5) * jitterMagnitude,
                          y: ring.cy + Math.sin(angle) * ring.r + (Math.random() - 0.5) * jitterMagnitude,
                          z: Math.floor(Math.random() * 10) 
                      });
                  }
              });

              if (interactive) container.dataset.ringLayout = JSON.stringify(ringLayout);
          }

          ringLayout.forEach((pos, cellIndex) => {
              if (cellIndex >= size) return;
              const el = document.createElement('div');
              const isTarget = cellIndex === targetIndex;
              el.className = `${baseClass}${shapeClass}${isTarget ? ' cell--target target' : ''}`;
              el.style.position = 'absolute';
              
              const sz = interactive ? `${90 / Math.sqrt(size)}%` : `${130 / Math.sqrt(size)}%`;
              el.style.width = sz; el.style.height = sz;
              if (!interactive) {
                  el.style.maxWidth = '16px'; el.style.maxHeight = '16px';
              }
              
              el.style.left = `calc(${pos.x}% - (${sz} / 2))`;
              el.style.top = `calc(${pos.y}% - (${sz} / 2))`;
              
              el.style.zIndex = isTarget ? 100 : pos.z;
              
              if(interactive) setupCellEvents(el, cellIndex);
              container.appendChild(el);
          });
      } else if (design === 'phygital_toss') {
          container.style.position = 'relative';
          container.style.width = '100%';
          container.style.aspectRatio = interactive ? '0.8' : '1';

          let targetsLayout = [];
          if (interactive && container.dataset.phygitalLayout) {
              targetsLayout = JSON.parse(container.dataset.phygitalLayout);
          } else {
              for (let i = 0; i < size; i++) {
                  const y = 5 + Math.random() * 65; 
                  const x = 10 + Math.random() * 80; 
                  const power = Math.floor((100 - y) * 1.05); 
                  targetsLayout.push({ x, y, power });
              }
              if (interactive) container.dataset.phygitalLayout = JSON.stringify(targetsLayout);
          }

          const isPeg = gameDefinition.category === 'ring_toss';

          targetsLayout.forEach((pos, cellIndex) => {
              if (cellIndex >= size) return;
              const el = document.createElement('div');
              const isTarget = cellIndex === targetIndex;
              
              el.className = `${baseClass} ${isTarget ? 'target cell--target' : ''}`;
              el.style.position = 'absolute';
              
              const depthScale = 0.5 + (pos.y / 100) * 0.8;
              const sz = interactive ? `${16 * depthScale}%` : '8px';
              
              el.style.width = sz; el.style.aspectRatio = '1';
              el.style.left = `calc(${pos.x}% - (${sz} / 2))`;
              el.style.top = `calc(${pos.y}% - (${sz} / 2))`;
              el.style.zIndex = Math.floor(pos.y);
              el.dataset.power = pos.power;

              if (isPeg) {
                  el.style.borderRadius = '50%';
                  el.style.background = 'radial-gradient(circle at 30% 30%, #e5e7eb, #9ca3af)';
                  el.style.boxShadow = '0 10px 15px rgba(0,0,0,0.6), inset -2px -2px 6px rgba(0,0,0,0.4)';
                  el.style.border = '1px solid #fff';
              } else {
                  el.style.borderRadius = '50%';
                  el.style.background = 'radial-gradient(circle at 30% 30%, #111, #000)';
                  el.style.boxShadow = 'inset 0 4px 8px rgba(0,0,0,0.9), 0 2px 0 rgba(255,255,255,0.2)';
                  el.style.border = '2px solid #333';
              }

              if(isTarget) {
                 el.style.boxShadow = isPeg ? '0 0 20px #facc15, 0 10px 15px rgba(0,0,0,0.6)' : 'inset 0 0 20px #facc15, 0 2px 0 rgba(255,255,255,0.2)';
                 el.style.borderColor = '#facc15';
              }
              
              container.appendChild(el);
          });

          if (interactive) {
              const launcher = document.createElement('div');
              launcher.className = 'skeuo-launcher-panel';
              launcher.innerHTML = `
                  <div style="width: 100%; padding: 0 20px; display: flex; flex-direction: column; align-items: center; gap: 6px;">
                      <div style="font-size: 10px; font-weight: 900; color: #9ca3af; text-transform: uppercase; letter-spacing: 2px;">Tension Launcher</div>
                      <input type="range" min="0" max="100" value="0" class="skeuo-slider" id="phygitalLauncherSlider" />
                  </div>
              `;
              container.appendChild(launcher);

              const slider = launcher.querySelector('#phygitalLauncherSlider');
              
              const fireLauncher = () => {
                  const power = parseInt(slider.value);
                  if (power < 5) return; 
                  
                  slider.disabled = true;
                  
                  const activeEl = container.querySelector('.cell--target');
                  if (!activeEl) return;
                  
                  const targetPower = parseInt(activeEl.dataset.power);
                  const tolerance = Math.max(5, 20 - Math.sqrt(size)); 
                  const isHit = Math.abs(power - targetPower) <= tolerance;

                  const proj = document.createElement('div');
                  const projType = gameDefinition.category === 'ring_toss' ? 'proj-ring' : gameDefinition.category === 'ball_toss' ? 'proj-ball' : 'proj-coin';
                  proj.className = `phygital-projectile ${projType}`;
                  
                  proj.style.left = '50%';
                  proj.style.bottom = '80px';
                  proj.style.transform = 'translate(-50%, 0) scale(1.5)';
                  container.appendChild(proj);
                  
                  void proj.offsetWidth;
                  
                  const destX = activeEl.offsetLeft + activeEl.offsetWidth/2;
                  const destY = activeEl.offsetTop + activeEl.offsetHeight/2;
                  
                  const powerDiff = power - targetPower;
                  const finalY = isHit ? destY : destY - (powerDiff * 3);

                  proj.style.left = `${destX}px`;
                  proj.style.top = `${finalY}px`;
                  proj.style.bottom = 'auto';
                  proj.style.transform = `translate(-50%, -50%) scale(${0.5 + (parseFloat(activeEl.style.top)/100)*0.8})`;

                  setTimeout(() => {
                      proj.remove();
                      slider.value = 0;
                      slider.disabled = false;
                      const nodes = Array.from(container.children).filter(c => c.classList.contains(baseClass));
                      const idx = nodes.indexOf(activeEl);
                      if (isHit) {
                          handleAction(idx, null, false);
                      } else {
                          handleAction(null, null, false);
                      }
                  }, 400);
              };

              slider.addEventListener('change', fireLauncher);
              slider.addEventListener('touchend', fireLauncher);
          }
      } else if (design === 'pickup_sticks') {
          container.style.position = 'relative';
          container.style.width = '100%';
          container.style.aspectRatio = '1';

          let stickLayout = [];
          if (interactive && container.dataset.stickLayout) {
              stickLayout = JSON.parse(container.dataset.stickLayout);
          } else {
              for (let i = 0; i < size; i++) {
                  stickLayout.push({
                      x: 15 + Math.random() * 70, // center x % (keep slightly away from extreme edges)
                      y: 15 + Math.random() * 70, // center y %
                      rot: Math.random() * 180, // rotation degrees
                      len: 30 + Math.random() * 40, // length %
                      colorIdx: Math.floor(Math.random() * 4), // for varied colors
                      z: i // natural stack order
                  });
              }
              if (interactive) container.dataset.stickLayout = JSON.stringify(stickLayout);
          }

          const colors = [
              ['#ef4444', '#991b1b'], // red
              ['#3b82f6', '#1e3a8a'], // blue
              ['#10b981', '#064e3b'], // green
              ['#8b5cf6', '#4c1d95']  // purple
          ];

          stickLayout.forEach((pos, cellIndex) => {
              if (cellIndex >= size) return;
              const el = document.createElement('div');
              const isTarget = cellIndex === targetIndex;

              el.className = `${baseClass} cell--stick ${isTarget ? 'target cell--target' : ''}`;
              
              const w = `${pos.len}%`;
              const h = interactive ? '12px' : '3px';

              el.style.width = w;
              el.style.height = h;
              el.style.left = `calc(${pos.x}% - (${w} / 2))`;
              el.style.top = `calc(${pos.y}% - (${h} / 2))`;
              el.style.transform = `rotate(${pos.rot}deg)`;
              
              // Target pops to absolute top
              el.style.zIndex = isTarget ? 1000 : pos.z;

              if (!isTarget) {
                  const c = colors[pos.colorIdx];
                  el.style.setProperty('--stick-bg', `linear-gradient(90deg, ${c[0]}, ${c[1]})`);
                  if (interactive) {
                      el.innerHTML = `<style>.cell--stick:nth-child(${cellIndex + 1})::before { background: linear-gradient(90deg, ${c[0]}, ${c[1]}); }</style>`;
                  } else {
                      el.style.background = `linear-gradient(90deg, ${c[0]}, ${c[1]})`;
                  }
              }

              if(interactive) setupCellEvents(el, cellIndex);
              container.appendChild(el);
          });
      }
    }

    function setupCellEvents(cell, index) {
      cell.addEventListener('touchstart', (e) => { e.preventDefault(); handleAction(index, e); }, {passive: false});
      cell.addEventListener('mousedown', (e) => handleAction(index, e));
    }

