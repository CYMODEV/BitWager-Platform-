    // Avatar Utility
    function getAvatarStyles(seed) {
        const colors = [
            ['#facc15', '#f97316'], ['#38bdf8', '#8b5cf6'], ['#4ade80', '#10b981'], 
            ['#f43f5e', '#e11d48'], ['#a78bfa', '#6d28d9']
        ];
        const emojis = ['🥷', '🤖', '👾', '🦊', '🦁', '🦉', '🦄', '🦅'];
        
        let hash = 0;
        for (let i = 0; i < seed.length; i++) hash = seed.charCodeAt(i) + ((hash << 5) - hash);
        
        const colorPair = colors[Math.abs(hash) % colors.length];
        const emoji = emojis[Math.abs(hash) % emojis.length];
        
        return {
            background: `linear-gradient(135deg, ${colorPair[0]}, ${colorPair[1]})`,
            emoji: emoji
        };
    }

