    function logTransaction(desc, amt) {
        const history = document.getElementById('txHistoryContainer');
        if(!history) return;
        const color = amt > 0 ? '#4ade80' : '#f97373';
        const sign = amt > 0 ? '+' : '';
        const html = `<div class="tx-row"><span>${desc}</span> <span style="color:${color};">${sign}${amt} BWT</span></div>`;
        history.insertAdjacentHTML('afterbegin', html);
        if(history.children.length > 5) history.removeChild(history.lastChild);
    }

