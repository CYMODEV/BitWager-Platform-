    // --- AI / GEMINI ---
    async function generateAiGame() {
      const theme = elements.aiThemeInput.value.trim() || "Surprise me";
      elements.aiGenerateBtn.disabled = true;
      elements.aiGenerateBtn.innerHTML = `<span class="loading-spinner"></span> Generating Architecting...`;
      
      const sys = "Output ONLY valid JSON for a SkillGameDefinition. Structure: { name, category, description, gridSize: (9, 16, 25, 36), boardDesign: ('square', 'circle', 'triangle', 'rectangle', 'overlapping_rings', 'gyro_sphere', 'phygital_toss', 'pickup_sticks'), timing: { roundCount, roundDurationMs, targetLifespanMs }, scoring: { baseHitPoints, baseMissPenalty } }.";
      try {
        const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
        const res = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ contents: [{ parts: [{ text: `Theme: ${theme}` }] }], systemInstruction: { parts: [{ text: sys }] } }) });
        const data = await res.json();
        const text = data.candidates?.[0]?.content?.parts?.[0]?.text;
        
        const jsonMatch = text.match(/\{[\s\S]*\}/);
        if (jsonMatch) {
          gameDefinition = JSON.parse(jsonMatch[0]);
          gameDefinition.gridSize = gameDefinition.gridSize || 16;
          syncFormFromDefinition();
          
          const newGameForReg = { id: "ai_gen_" + Date.now(), ...gameDefinition };
          gameRegistry.unshift(newGameForReg);
          populateRegistry();
          
          pushToFeed({ type: 'publish', user: 'AI Architect', avatar: '🤖', game: newGameForReg, timestamp: new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}), likes: 0 });
        }
      } catch (err) {
        console.error("AI Generation Error: ", err);
      } finally {
        elements.aiGenerateBtn.disabled = false;
        elements.aiGenerateBtn.innerHTML = `<span> ✨  Generate AI Game Idea</span>`;
      }
    }

